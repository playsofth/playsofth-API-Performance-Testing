*** Variables ***
${BASE_URL}     https://jsonplaceholder.typicode.com
${OUTPUT_FILE}  D:/Robottest/test_output.txt
${REFERENCE_FILE}  D:/Robottest/reference.txt

*** Test Cases ***
API Test Example
    Set Log Level      DEBUG    
    [Documentation]    Example test case to demonstrate API requests.
    [Tags]             apitest
    Create Session     jsonplaceholder_session    ${BASE_URL}
    Create File        ${OUTPUT_FILE}
    File Should Exist    path=${OUTPUT_FILE}
    ${resp}=           GET On Session             jsonplaceholder_session    /users
    ${resp_posts}=     GET On Session             jsonplaceholder_session    /posts
    Should Be Equal As Integers    ${resp_posts.status_code}    200
    ${resp_comments}=  GET On Session             jsonplaceholder_session    /comments
    Should Be Equal As Integers    ${resp_comments.status_code}    200
    ${users_list}=     Set Variable               ${resp.json()}
    ${posts_list}=     Set Variable               ${resp_posts.json()}
    ${comments_list}=  Set Variable               ${resp_comments.json()}
    Should Not Be Empty    ${users_list}

    # Add assertions to verify the structure of the user data
    ${first_user}=     Get From List              ${users_list}    0
    ${first_posts}=    Get From List              ${posts_list}    0
    Dictionary Should Contain Key    ${first_user}    id
    Dictionary Should Contain Key    ${first_user}    username
    Dictionary Should Contain Key    ${first_user}    name

    # Add assertions to verify the structure of the user posts    
    ${first_posts}=    Get From List              ${posts_list}    0
    Dictionary Should Contain Key    ${first_posts}   userId 
    Should Not Be Equal    ${first_posts}[userId]    ${None}

    ${count_users}=    Get Length                 ${users_list}
    ${count_posts}=    Get Length                 ${posts_list}
    ${count_comments}=    Get Length              ${comments_list}
    Append To File     ${OUTPUT_FILE}    --- Number of users: ${count_users}\n
    Append To File     ${OUTPUT_FILE}    --- Number of posts: ${count_posts}\n
    Append To File     ${OUTPUT_FILE}    --- Number of comments: ${count_comments}\n
    Append To File     ${OUTPUT_FILE}    --- User Details ---\n

    Comment    Filter posts for each user and write to file
    FOR    ${user}    IN    @{users_list}
        Append To File    ${OUTPUT_FILE}    --- Posts for user: ${user}[name] (ID: ${user}[id]) ---\n
        ${user_id}=       Set Variable    ${user}[id]
        ${is_int}=        Evaluate    isinstance($user_id, int)
        Should Be True    ${is_int}    msg=User ID should be an integer.
        ${user_posts}=    Evaluate    [post for post in $posts_list if post['userId'] == $user_id]
        FOR    ${post}    IN    @{user_posts}    # Loop through the filtered list of posts
            Append To File    ${OUTPUT_FILE}    - Post Title: ${post}[title]\n
            ${post_id}=       Set Variable    ${post}[id]
            ${is_int}=        Evaluate    isinstance($post_id, int)
            Should Be True    ${is_int}    msg=Post ID should be an integer.
            ${post_comments}=    Evaluate    [comment for comment in $comments_list if comment['postId'] == $post_id]
            ${count_filtered}=    Get Length                 ${post_comments}
            Append To File     ${OUTPUT_FILE}    --- Number of filtered comments: ${count_filtered}\n
            FOR    ${comment}    IN    @{post_comments}
                Append To File    ${OUTPUT_FILE}    - Comment Body: ${comment}[body]\n
            END
        END
    END 
    Diff Files          ${OUTPUT_FILE}    ${REFERENCE_FILE}    fail_on_difference=True
    #Remove File         ${OUTPUT_FILE}